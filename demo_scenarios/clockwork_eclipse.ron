Visual(
    id: "demo:clockwork_eclipse",
    visual: [
        // ground / void shadow
        Ellipse(
            rx: 92.0, ry: 16.0,
            fill: "#07090f",
            offset: (0.0, 64.0),
            opacity: E("0.18 + 0.05 * sin(self.time * 1.1)"),
        ),

        // outer aura
        Circle(
            radius: 74.0,
            fill: Color(
                r: E("0.05 + 0.03 * sin(self.time * 0.7)"),
                g: E("0.20 + 0.08 * sin(self.time * 0.7 + 2.094)"),
                b: E("0.32 + 0.12 * sin(self.time * 0.7 + 4.189)"),
                a: 1.0,
            ),
            opacity: E("0.16 + 0.05 * sin(self.time * 1.4)"),
        ),

        // petal crown
