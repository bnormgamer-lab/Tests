        Ellipse(rx: 3.2, ry: 2.5, fill: "#c0b830", offset: (30.0, -12.5)),
        Ellipse(rx: 1.2, ry: 2.2, fill: "#181818", offset: (30.5, -12.5)),
        Circle(radius: 0.9, fill: "#f0f0f0", offset: (29.5, -13.3)),
    ],
),
Visual(
    id: "demo:forest_scene",
    visual: [
        // ========== SKY LAYER ==========
